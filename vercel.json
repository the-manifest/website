{
  "rewrites": [
    { "source": "/en", "destination": "/index.html" },
    { "source": "/fr", "destination": "/index.html" },
    { "source": "/team", "destination": "/pages/team.html" },
    { "source": "/legal-notice", "destination": "/pages/legal-notice.html" },
    { "source": "/terms", "destination": "/pages/terms.html" },
    { "source": "/privacy-policy", "destination": "/pages/privacy-policy.html" }
  ],
  "headers": [
    {
      "source": "/public/assets/video/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    },
    {
      "source": "/public/assets/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
